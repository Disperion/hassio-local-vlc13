{
    "name": "Local VLC 13",
    "version": "18",
    "slug": "local_vlc_13",
    "description": "Play VLC player",
    "url": "https://github.com/Disperion/hassio-local-vlc13",    
    "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
    "startup": "application",
    "boot": "auto",
    "options": {
        "telnet_password": "mypassword",
        "http_password": "mypassword"
    },    
    "schema": {
        "telnet_password": "str",
        "http_password": "str"
    },
    "audio": true,
    "ports":{
        "9893/tcp":9893,
        "4213/tcp":4213
    },
    "webui": "http://[HOST]:[PORT:9893]/",
    "map": ["share:ro", "ssl"]
  }
